# Adapted from eyeling/examples/fibonacci.n3
# Computes exact Fibonacci values up to fib(10000).
# The recurrence is expanded into deterministic SRL rules so the example
# finishes under the default fixpoint settings while still deriving fib(10000).

PREFIX : <http://example/eyeling/fibonacci/>

OUTPUT {
  :test :fib8 ?fib8 .
  :test :fib10000 ?fib10000 .
}

DATA {
  :n0 :index 0 ; :fib 0 .
  :n1 :index 1 ; :fib 1 .
}

RULE { :n2 :index 2 ; :fib ?sum }
WHERE { :n0 :fib ?a . :n1 :fib ?b . SET(?sum := ?a + ?b) }

RULE { :n3 :index 3 ; :fib ?sum }
WHERE { :n1 :fib ?a . :n2 :fib ?b . SET(?sum := ?a + ?b) }

RULE { :n4 :index 4 ; :fib ?sum }
