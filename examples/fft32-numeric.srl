  SET(?y29r := ?e13r - ?t13r)
  SET(?y29i := ?e13i - ?t13i)
  :W32_14 :re ?w14r ; :im ?w14i .
  SET(?t14r := (?w14r * ?o14r) - (?w14i * ?o14i))
  SET(?t14i := (?w14r * ?o14i) + (?w14i * ?o14r))
  SET(?y14r := ?e14r + ?t14r)
  SET(?y14i := ?e14i + ?t14i)
  SET(?y30r := ?e14r - ?t14r)
  SET(?y30i := ?e14i - ?t14i)
  :W32_15 :re ?w15r ; :im ?w15i .
  SET(?t15r := (?w15r * ?o15r) - (?w15i * ?o15i))
  SET(?t15i := (?w15r * ?o15i) + (?w15i * ?o15r))
  SET(?y15r := ?e15r + ?t15r)
