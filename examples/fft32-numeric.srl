  SET(?y24r := ?e8r - ?t8r)
  SET(?y24i := ?e8i - ?t8i)
  :W32_9 :re ?w9r ; :im ?w9i .
  SET(?t9r := (?w9r * ?o9r) - (?w9i * ?o9i))
  SET(?t9i := (?w9r * ?o9i) + (?w9i * ?o9r))
  SET(?y9r := ?e9r + ?t9r)
  SET(?y9i := ?e9i + ?t9i)
  SET(?y25r := ?e9r - ?t9r)
