  :W32_12 :re ?w12r ; :im ?w12i .
  SET(?t12r := (?w12r * ?o12r) - (?w12i * ?o12i))
  SET(?t12i := (?w12r * ?o12i) + (?w12i * ?o12r))
  SET(?y12r := ?e12r + ?t12r)
  SET(?y12i := ?e12i + ?t12i)
  SET(?y28r := ?e12r - ?t12r)
  SET(?y28i := ?e12i - ?t12i)
  :W32_13 :re ?w13r ; :im ?w13i .
  SET(?t13r := (?w13r * ?o13r) - (?w13i * ?o13i))
  SET(?t13i := (?w13r * ?o13i) + (?w13i * ?o13r))
  SET(?y13r := ?e13r + ?t13r)
