# Project the computed 32-bin spectrum as the query answer.
RULE {
  ?in :fft ?spectrum .
  ?spectrum a :FFT32Spectrum ;
    :fftInput ?in ;
    :fftWaveformName ?name ;
    :bin0Re ?y0r ; :bin0Im ?y0i ;
    :bin1Re ?y1r ; :bin1Im ?y1i ;
    :bin2Re ?y2r ; :bin2Im ?y2i ;
    :bin3Re ?y3r ; :bin3Im ?y3i ;
    :bin4Re ?y4r ; :bin4Im ?y4i ;
    :bin5Re ?y5r ; :bin5Im ?y5i ;
    :bin6Re ?y6r ; :bin6Im ?y6i ;
    :bin7Re ?y7r ; :bin7Im ?y7i ;
    :bin8Re ?y8r ; :bin8Im ?y8i ;
    :bin9Re ?y9r ; :bin9Im ?y9i ;
    :bin10Re ?y10r ; :bin10Im ?y10i ;
    :bin11Re ?y11r ; :bin11Im ?y11i ;
    :bin12Re ?y12r ; :bin12Im ?y12i ;
    :bin13Re ?y13r ; :bin13Im ?y13i ;
    :bin14Re ?y14r ; :bin14Im ?y14i ;
    :bin15Re ?y15r ; :bin15Im ?y15i ;
    :bin16Re ?y16r ; :bin16Im ?y16i ;
    :bin17Re ?y17r ; :bin17Im ?y17i ;
    :bin18Re ?y18r ; :bin18Im ?y18i ;
    :bin19Re ?y19r ; :bin19Im ?y19i ;
    :bin20Re ?y20r ; :bin20Im ?y20i ;
    :bin21Re ?y21r ; :bin21Im ?y21i ;
    :bin22Re ?y22r ; :bin22Im ?y22i ;
    :bin23Re ?y23r ; :bin23Im ?y23i ;
    :bin24Re ?y24r ; :bin24Im ?y24i ;
    :bin25Re ?y25r ; :bin25Im ?y25i ;
    :bin26Re ?y26r ; :bin26Im ?y26i ;
    :bin27Re ?y27r ; :bin27Im ?y27i ;
    :bin28Re ?y28r ; :bin28Im ?y28i ;
    :bin29Re ?y29r ; :bin29Im ?y29i ;
    :bin30Re ?y30r ; :bin30Im ?y30i ;
    :bin31Re ?y31r ; :bin31Im ?y31i .
}
WHERE {
  ?vector a :Vector32 ; :source ?in .
  ?in :waveformName ?name .
  ?vector :y0 ?y0 .
  ?y0 :re ?y0r ; :im ?y0i .
  ?vector :y1 ?y1 .
  ?y1 :re ?y1r ; :im ?y1i .
  ?vector :y2 ?y2 .
  ?y2 :re ?y2r ; :im ?y2i .
  ?vector :y3 ?y3 .
  ?y3 :re ?y3r ; :im ?y3i .
  ?vector :y4 ?y4 .
  ?y4 :re ?y4r ; :im ?y4i .
  ?vector :y5 ?y5 .
  ?y5 :re ?y5r ; :im ?y5i .
  ?vector :y6 ?y6 .
  ?y6 :re ?y6r ; :im ?y6i .
  ?vector :y7 ?y7 .
  ?y7 :re ?y7r ; :im ?y7i .
  ?vector :y8 ?y8 .
  ?y8 :re ?y8r ; :im ?y8i .
  ?vector :y9 ?y9 .
  ?y9 :re ?y9r ; :im ?y9i .
  ?vector :y10 ?y10 .
  ?y10 :re ?y10r ; :im ?y10i .
  ?vector :y11 ?y11 .
  ?y11 :re ?y11r ; :im ?y11i .
  ?vector :y12 ?y12 .
  ?y12 :re ?y12r ; :im ?y12i .
  ?vector :y13 ?y13 .
  ?y13 :re ?y13r ; :im ?y13i .
