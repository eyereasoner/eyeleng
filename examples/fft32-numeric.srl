  ?vector :y28 ?y28 .
  ?y28 :re ?y28r ; :im ?y28i .
  ?vector :y29 ?y29 .
  ?y29 :re ?y29r ; :im ?y29i .
  ?vector :y30 ?y30 .
  ?y30 :re ?y30r ; :im ?y30i .
  ?vector :y31 ?y31 .
  ?y31 :re ?y31r ; :im ?y31i .
  SET(?spectrum := BNODE(CONCAT(STR(?vector), "-spectrum")))
}

