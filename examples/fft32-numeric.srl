  SET(?y31r := ?e15r - ?t15r)
  SET(?y31i := ?e15i - ?t15i)
  SET(?y0 := BNODE(CONCAT(STR(?v), "-y0")))
  SET(?y1 := BNODE(CONCAT(STR(?v), "-y1")))
