  ?y14 :re ?y14r ; :im ?y14i .
  ?vector :y15 ?y15 .
  ?y15 :re ?y15r ; :im ?y15i .
  ?vector :y16 ?y16 .
  ?y16 :re ?y16r ; :im ?y16i .
  ?vector :y17 ?y17 .
  ?y17 :re ?y17r ; :im ?y17i .
  ?vector :y18 ?y18 .
  ?y18 :re ?y18r ; :im ?y18i .
  ?vector :y19 ?y19 .
  ?y19 :re ?y19r ; :im ?y19i .
  ?vector :y20 ?y20 .
  ?y20 :re ?y20r ; :im ?y20i .
  ?vector :y21 ?y21 .
  ?y21 :re ?y21r ; :im ?y21i .
  ?vector :y22 ?y22 .
  ?y22 :re ?y22r ; :im ?y22i .
  ?vector :y23 ?y23 .
  ?y23 :re ?y23r ; :im ?y23i .
  ?vector :y24 ?y24 .
